{
  "data" : {
    "model" : {
      "splitRules" : false,
      "confidenceAndWeight" : false,
      "provideStatistics" : false,
      "useAdditionalParentheses" : false,
      "scorePmmlRecordCount" : false,
      "scoreTableRecordCount" : false,
      "scoreTableRecordCountPrefix" : "Record count ",
      "scorePmmlProbability" : false,
      "scoreTableProbability" : false,
      "scoreTableProbabilityPrefix" : "Probability "
    }
  },
  "schema" : {
    "type" : "object",
    "properties" : {
      "model" : {
        "type" : "object",
        "properties" : {
          "confidenceAndWeight" : {
            "type" : "boolean",
            "title" : "Add confidence and weight columns",
            "description" : "From PMML the <a href=\"http://www.dmg.org/v4-2-1/RuleSet.html#xsdGroup_Rule\">confidence and weight</a> attributes are extracted to columns. (It will create columns with missing values.)",
            "default" : false
          },
          "provideStatistics" : {
            "type" : "boolean",
            "title" : "Add Record count and Number of correct statistics columns",
            "description" : "In PMML, the <tt>recordCount</tt> and the <tt>nbCorrect</tt> attributes provide statistics about the input (training/test/validation) data, with this option, this information can be extracted to the columns: <b>Record count</b> and <b>Number of correct</b>",
            "default" : false
          },
          "scorePmmlProbability" : {
            "type" : "boolean",
            "title" : "Provide score distribution probability in PMML",
            "description" : "PMML will store the information obtained from the rules on probabilities of score distribution (in the training data what the probability was of certain values for that decision tree leaf)",
            "default" : false
          },
          "scorePmmlRecordCount" : {
            "type" : "boolean",
            "title" : "Provide score distribution record count in PMML",
            "description" : "PMML will store the information obtained from the rules on record counts of score distribution (how many times the different values were present in the training data, not necessarily integer)",
            "default" : false
          },
          "scoreTableProbability" : {
            "type" : "boolean",
            "title" : "Provide score distribution probability in table with column name prefix",
            "description" : "Information about the probabilities of score distribution is saved to the table with the specified prefix.",
            "default" : false
          },
          "scoreTableProbabilityPrefix" : {
            "type" : "string",
            "title" : "Probability column prefix",
            "description" : "Prefix for the score distribution probability columns.",
            "default" : "Probability "
          },
          "scoreTableRecordCount" : {
            "type" : "boolean",
            "title" : "Provide score distribution record count in table with column name prefix",
            "description" : "Information about the record count of score distribution is saved to the table with the specified prefix.",
            "default" : false
          },
          "scoreTableRecordCountPrefix" : {
            "type" : "string",
            "title" : "Record count column prefix",
            "description" : "Prefix for the score distribution record count columns.",
            "default" : "Record count "
          },
          "splitRules" : {
            "type" : "boolean",
            "title" : "Split rules to condition and outcome columns",
            "description" : "When checked, two columns will be created for the rules, <b>Condition</b> and <b>Outcome</b>, otherwise the rules will reside in a single column, <b>Rule</b>.",
            "default" : false
          },
          "useAdditionalParentheses" : {
            "type" : "boolean",
            "title" : "Use additional parentheses to document precedence rules",
            "description" : "If checked the output will contain additional parenthesis around rule parts to clearly document precedence. For instance, NOT is a stronger operator than AND than OR - using parenthesis improves readability. Checking this option does not change any of the rule logic.",
            "default" : false
          }
        }
      }
    }
  },
  "ui_schema" : {
    "elements" : [ {
      "type" : "Control",
      "scope" : "#/properties/model/properties/splitRules",
      "options" : {
        "format" : "checkbox"
      }
    }, {
      "type" : "Control",
      "scope" : "#/properties/model/properties/confidenceAndWeight",
      "options" : {
        "format" : "checkbox"
      }
    }, {
      "type" : "Control",
      "scope" : "#/properties/model/properties/provideStatistics",
      "options" : {
        "format" : "checkbox"
      }
    }, {
      "type" : "Control",
      "scope" : "#/properties/model/properties/useAdditionalParentheses",
      "options" : {
        "format" : "checkbox"
      }
    }, {
      "label" : "Score Distribution",
      "type" : "Section",
      "elements" : [ {
        "type" : "Control",
        "scope" : "#/properties/model/properties/scorePmmlRecordCount",
        "options" : {
          "format" : "checkbox"
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/scoreTableRecordCount",
        "options" : {
          "format" : "checkbox"
        },
        "rule" : {
          "effect" : "SHOW",
          "condition" : {
            "scope" : "#/properties/model/properties/scorePmmlRecordCount",
            "schema" : {
              "const" : true
            }
          }
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/scoreTableRecordCountPrefix",
        "rule" : {
          "effect" : "SHOW",
          "condition" : {
            "type" : "AND",
            "conditions" : [ {
              "scope" : "#/properties/model/properties/scorePmmlRecordCount",
              "schema" : {
                "const" : true
              }
            }, {
              "scope" : "#/properties/model/properties/scoreTableRecordCount",
              "schema" : {
                "const" : true
              }
            } ]
          }
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/scorePmmlProbability",
        "options" : {
          "format" : "checkbox"
        },
        "rule" : {
          "effect" : "SHOW",
          "condition" : {
            "scope" : "#/properties/model/properties/scorePmmlRecordCount",
            "schema" : {
              "const" : true
            }
          }
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/scoreTableProbability",
        "options" : {
          "format" : "checkbox"
        },
        "rule" : {
          "effect" : "SHOW",
          "condition" : {
            "type" : "AND",
            "conditions" : [ {
              "scope" : "#/properties/model/properties/scorePmmlRecordCount",
              "schema" : {
                "const" : true
              }
            }, {
              "scope" : "#/properties/model/properties/scorePmmlProbability",
              "schema" : {
                "const" : true
              }
            } ]
          }
        }
      }, {
        "type" : "Control",
        "scope" : "#/properties/model/properties/scoreTableProbabilityPrefix",
        "rule" : {
          "effect" : "SHOW",
          "condition" : {
            "type" : "AND",
            "conditions" : [ {
              "type" : "AND",
              "conditions" : [ {
                "scope" : "#/properties/model/properties/scorePmmlRecordCount",
                "schema" : {
                  "const" : true
                }
              }, {
                "scope" : "#/properties/model/properties/scorePmmlProbability",
                "schema" : {
                  "const" : true
                }
              } ]
            }, {
              "scope" : "#/properties/model/properties/scoreTableProbability",
              "schema" : {
                "const" : true
              }
            } ]
          }
        }
      } ]
    } ]
  },
  "persist" : {
    "type" : "object",
    "properties" : {
      "model" : {
        "type" : "object",
        "properties" : {
          "splitRules" : {
            "configKey" : "split<dot>rules"
          },
          "confidenceAndWeight" : {
            "configKey" : "confidence<dot>and<dot>weight"
          },
          "provideStatistics" : {
            "configKey" : "statistics"
          },
          "useAdditionalParentheses" : {
            "configKey" : "additional<dot>parentheses"
          },
          "scorePmmlRecordCount" : {
            "configKey" : "pmml<dot>score<dot>recordCount"
          },
          "scoreTableRecordCount" : {
            "configKey" : "table<dot>score<dot>recordCount"
          },
          "scoreTableRecordCountPrefix" : {
            "configKey" : "table<dot>score<dot>recordCount<dot>prefix"
          },
          "scorePmmlProbability" : {
            "configKey" : "pmml<dot>score<dot>probability"
          },
          "scoreTableProbability" : {
            "configKey" : "table<dot>score<dot>probability"
          },
          "scoreTableProbabilityPrefix" : {
            "configKey" : "table<dot>score<dot>probability<dot>prefix"
          }
        }
      }
    }
  }
}