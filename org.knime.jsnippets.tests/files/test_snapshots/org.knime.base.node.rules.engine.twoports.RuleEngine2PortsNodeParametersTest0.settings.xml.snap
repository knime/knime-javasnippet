    <entry key="rule.weight.column" type="xstring" isnull="true" value=""/>
    <entry key="compute.confidence" type="xboolean" value="false"/>
    <entry key="prediction.confidence.column" type="xstring" value="Confidence"/>
    <entry key="provide.statistics" type="xboolean" value="true"/>
    <entry key="validate.column" type="xstring" isnull="true" value=""/>
