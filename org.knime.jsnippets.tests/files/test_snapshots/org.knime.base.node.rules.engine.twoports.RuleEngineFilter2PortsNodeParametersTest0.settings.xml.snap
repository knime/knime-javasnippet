<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.knime.org/2008/09/XMLConfig" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.knime.org/2008/09/XMLConfig http://www.knime.org/XMLConfig_2008_09.xsd" key="test">
    <entry key="dictionaryMode" type="xstring" value="CONDITION_AND_VALUE"/>
    <entry key="ruleColumn" type="xstring" value="Rule"/>
    <entry key="conditionColumn" type="xstring" value="Rule"/>
    <entry key="valueColumn" type="xstring" value=""/>
    <entry key="treat.outcomes.with.dollar.as.references" type="xboolean" value="true"/>
    <entry key="disallowLongOutputForCompatibility" type="xboolean" value="false"/>
    <entry key="include" type="xboolean" value="true"/>
</config>
